generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Slot {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endAt      DateTime
  isBooked   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, startsAt, endAt])
  @@index([propertyId, startsAt])
}

model Property {
  id        String    @id @default(cuid())
  ref       String    @unique //e.g. "BST-12A"
  address   String
  postcode  String?
  bedrooms  Int?
  rentPcm   Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  enquiries Enquiry[]
  slots     Slot[]
}

model Enquiry {
  id          String        @id @default(cuid())
  rawText     String
  source      String //"email" | "web" |"phone"
  status      EnquiryStatus @default(PENDING)
  intent      Intent?
  contactName String?
  email       String?
  phone       String?

  propertyRef String?

  propertyId   String?
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  triageResult triageResult?
  draftReply   DraftReply?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([propertyId])
}

model DraftReply {
  id        String  @id @default(cuid())
  enquiryId String  @unique
  enquiry   Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  subject   String?
  body      String
  method    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model triageResult {
  id        String  @id @default(cuid())
  enquiryId String  @unique
  enquiry   Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  intent     Intent?
  confidence Float?
  entities   Json?
  method     String  @default("rules")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EnquiryStatus {
  PENDING
  DRAFTED
  SENT
  SCHEDULED
  CLOSED
}

enum Intent {
  VIEWING
  VALUATION
  MAINTENANCE
  GENERAL
  SPAM
}
